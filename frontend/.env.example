# URL base da API do backend (ProTalent API)
VITE_API_URL=http://localhost:3333

# Supabase (frontend usa APENAS a URL do projeto e a anon/publishable key)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Confirmação de e-mail no cadastro (comportamento do APP em dev/prod)
# false (dev): cadastro segue sem exigir confirmação de e-mail
# true  (prod): exige confirmação de e-mail antes de acessar
VITE_AUTH_EMAIL_CONFIRMATION_REQUIRED=false
